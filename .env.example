# ══════════════════════════════════════════════════════════════════════════════
# Big Red Command Center — v2026.ULTRA-ELITE Configuration
# ══════════════════════════════════════════════════════════════════════════════

# ── Auth ──────────────────────────────────────────────────────────────────────
# Required. Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# If unset, the server generates an ephemeral token printed to stdout on startup.
RACE_API_TOKEN=

# ── Event ─────────────────────────────────────────────────────────────────────
EVENT_NAME="Big Red 5K 2026"
EVENT_DATE=2026-05-15

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=race.db
BACKUP_DIR=backups

# ── File uploads ──────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=10

# ── YOLO26 bib detection ──────────────────────────────────────────────────────
# Path to a trained YOLOv8/YOLO11 bib-detection model (.pt file).
# If absent, detection runs in simulation mode.
YOLO_MODEL_PATH=models/bib_detector.pt

# ── Cameras ───────────────────────────────────────────────────────────────────
# Side-view line-scan camera device index (default 0 = /dev/video0)
CAMERA_INDEX_SIDE=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# ── Video clips ───────────────────────────────────────────────────────────────
VIDEO_CLIP_PRE_S=2
VIDEO_CLIP_POST_S=3

# ── IR / LiDAR depth sensor ───────────────────────────────────────────────────
# Runner must be within this distance to trigger a finish event (millimetres)
DEPTH_THRESHOLD_MM=1000

# ── 5G results push ───────────────────────────────────────────────────────────
# Optional webhook URL. After each VAR decision, the finish event is POSTed here.
# Example: a Cloudflare Worker or public API that updates the public leaderboard.
RESULTS_WEBHOOK_URL=

# ── Supabase Cloud Standings ──────────────────────────────────────────────────
# Optional. If set, results are upserted to a Supabase `race_results` table.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_TABLE=race_results

# ── Confirmation Chime ────────────────────────────────────────────────────────
# Set to 0 to disable the browser-side chime. Default enabled.
CHIME_ENABLED=1
