{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/uploads/(.*)", "dest": "/api/index.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/ws", "dest": "/api/index.py" },
    { "src": "/(register|checkin|var|results|announcer|overlay|livestream|receipt)", "dest": "/api/index.py" },
    { "src": "/phone/(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/api/index.py" }
  ]
}
